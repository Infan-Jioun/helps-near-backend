generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String              @id @default(uuid())
  name             String
  email            String              @unique
  emailVerified    Boolean             @default(false)
  phone            String?
  role             Role                @default(USER)
  latitude         Float?
  longitude        Float?
  status           Status              @default(ACTIVE)
  isVolunteer      Boolean             @default(false)
  isAvailable      Boolean             @default(false)
  profileImage     String?
  bloodGroup       BloodGroup?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  accounts         Account[]
  adminProfile     AdminProfile?
  emergencies      Emergency[]         @relation("UserEmergencies")
  notifications    Notification[]
  payments         Payment[]
  ratingsGiven     Rating[]            @relation("RatingsGiven")
  ratingsReceived  Rating[]            @relation("RatingsReceived")
  sessions         Session[]
  volunteerProfile VolunteerProfile?
  responses        VolunteerResponse[] @relation("VolunteerResponses")

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model AdminProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  designation String?
  contactNo   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profile")
}

model VolunteerProfile {
  id            String           @id @default(uuid())
  userId        String           @unique
  name          String
  email         String           @unique
  nidNumber     String?          @unique
  skills        VolunteerSkill[]
  isVerified    Boolean          @default(false)
  totalHelped   Int              @default(0)
  averageRating Float            @default(0.0)
  bio           String?
  latitude      Float?
  longitude     Float?
  lastSeenAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("volunteer_profile")
}

model Emergency {
  id          String              @id @default(uuid())
  userId      String
  type        EmergencyType
  status      EmergencyStatus     @default(PENDING)
  description String?
  imageUrl    String?
  latitude    Float
  longitude   Float
  address     String?
  district    String?
  isPriority  Boolean             @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        User                @relation("UserEmergencies", fields: [userId], references: [id])
  payment     Payment?
  rating      Rating?
  responses   VolunteerResponse[]

  @@index([status])
  @@index([userId])
  @@index([latitude, longitude])
  @@map("emergency")
}

model VolunteerResponse {
  id                  String    @id @default(uuid())
  emergencyId         String
  volunteerId         String
  acceptedAt          DateTime  @default(now())
  arrivedAt           DateTime?
  estimatedArrivalMin Int?
  emergency           Emergency @relation(fields: [emergencyId], references: [id])
  volunteer           User      @relation("VolunteerResponses", fields: [volunteerId], references: [id])

  @@unique([emergencyId, volunteerId])
  @@index([volunteerId])
  @@map("volunteer_response")
}

model Payment {
  id            String        @id @default(uuid())
  userId        String
  emergencyId   String        @unique
  amount        Float
  currency      String        @default("BDT")
  method        PaymentMethod
  transactionId String?       @unique
  status        PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  emergency     Emergency     @relation(fields: [emergencyId], references: [id])
  user          User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("payment")
}

model Rating {
  id          String    @id @default(uuid())
  emergencyId String    @unique
  fromUserId  String
  toUserId    String
  score       Int
  comment     String?
  createdAt   DateTime  @default(now())
  emergency   Emergency @relation(fields: [emergencyId], references: [id])
  from        User      @relation("RatingsGiven", fields: [fromUserId], references: [id])
  to          User      @relation("RatingsReceived", fields: [toUserId], references: [id])

  @@map("rating")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String
  isRead    Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notification")
}

enum Role {
  USER
  ADMIN
  VOLUNTEER
}

enum Status {
  BLOCKED
  DELETED
  ACTIVE
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

enum EmergencyType {
  MEDICAL
  FIRE
  ACCIDENT
  FLOOD
  CRIME
  OTHER
}

enum EmergencyStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum VolunteerSkill {
  FIRST_AID
  FIREFIGHTING
  RESCUE
  MEDICAL
  FLOOD_RESPONSE
  GENERAL
}

enum PaymentMethod {
  STRIPE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}
