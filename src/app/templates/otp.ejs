<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Helps Near OTP</title>
</head>

<body style="margin:0;padding:0;background:#ffffff;font-family:Arial,sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" style="background:#ffffff;padding:40px 0;">
    <tr>
      <td align="center">
        <table width="520" cellpadding="0" cellspacing="0"
          style="background:#ffffff;border-radius:12px;overflow:hidden;border:1px solid #EF4444;">

          <!-- HEADER -->
          <tr>
            <td style="background:#EF4444;padding:32px;text-align:center;">
              <table cellpadding="0" cellspacing="0" style="margin:0 auto 10px;">
                <tr>
                  <td style="background:rgba(255,255,255,0.2);border-radius:8px;padding:8px 18px;">
                    <span style="color:#ffffff;font-size:20px;font-weight:700;letter-spacing:1px;">
                      &#9888; Helps Near
                    </span>
                  </td>
                </tr>
              </table>
              <p style="color:rgba(255,255,255,0.9);font-size:13px;margin:0;">
                Bangladesh Emergency Response Network
              </p>
            </td>
          </tr>

          <!-- BODY -->
          <tr>
            <td style="padding:36px 32px;background:#ffffff;">

              <p style="color:#888888;font-size:14px;margin:0 0 4px;">Hello,</p>
              <h2 style="color:#EF4444;font-size:22px;font-weight:700;margin:0 0 20px;">
                <%= name %>
              </h2>

              <p style="color:#555555;font-size:14px;line-height:1.7;margin:0 0 28px;">
                Use the OTP code below to verify your
                <strong style="color:#EF4444;">Helps Near</strong> account.
                This code is valid for
                <strong style="color:#EF4444;">10 minutes</strong> only.
              </p>

              <!-- OTP BOX -->
              <table width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 28px;">
                <tr>
                  <td align="center">
                    <div
                      style="background:#ffffff;border:2px solid #EF4444;border-radius:10px;padding:24px 40px;display:inline-block;">
                      <p
                        style="color:#aaaaaa;font-size:11px;margin:0 0 10px;letter-spacing:2px;text-transform:uppercase;">
                        Your OTP Code
                      </p>
                      <p
                        style="color:#EF4444;font-size:42px;font-weight:700;letter-spacing:12px;margin:0;font-family:monospace;">
                        <%= otp %>
                      </p>
                    </div>
                  </td>
                </tr>
              </table>

              <!-- WARNING -->
              <table width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 24px;">
                <tr>
                  <td
                    style="background:#FEF2F2;border-left:3px solid #EF4444;border-radius:0 6px 6px 0;padding:12px 16px;">
                    <p style="color:#EF4444;font-size:13px;margin:0;">
                      &#9888;&nbsp; Never share this OTP with anyone.
                      Helps Near will never ask for your OTP.
                    </p>
                  </td>
                </tr>
              </table>

              <p style="color:#aaaaaa;font-size:13px;line-height:1.6;margin:0;">
                If you did not request this, please ignore this email.
                Your account remains safe and secure.
              </p>

            </td>
          </tr>

          <!-- DIVIDER -->
          <tr>
            <td style="padding:0 32px;">
              <div style="height:1px;background:#FEE2E2;"></div>
            </td>
          </tr>

          <!-- FOOTER -->
          <tr>
            <td style="padding:20px 32px;text-align:center;background:#ffffff;">
              <p style="color:#aaaaaa;font-size:12px;margin:0 0 6px;">
                &copy; 2026 Helps Near — Bangladesh Emergency Response Network
              </p>
              <p style="color:#cccccc;font-size:11px;margin:0;">
                This is an automated email. Please do not reply.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>

</html>