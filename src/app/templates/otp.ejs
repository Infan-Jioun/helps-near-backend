<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Helps Near OTP</title>
</head>
<body style="margin:0;padding:0;background:#1A1A2E;font-family:Arial,sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" style="background:#1A1A2E;padding:40px 0;">
    <tr>
      <td align="center">
        <table width="520" cellpadding="0" cellspacing="0" style="background:#16213E;border-radius:12px;overflow:hidden;border:1px solid rgba(192,57,43,0.3);">

     
          <tr>
            <td style="background:#C0392B;padding:28px 32px;text-align:center;">
              <table cellpadding="0" cellspacing="0" style="margin:0 auto;">
                <tr>
                  <td style="background:rgba(255,255,255,0.15);border-radius:8px;padding:8px 14px;">
                    <span style="color:#ffffff;font-size:18px;font-weight:700;letter-spacing:1px;">
                      &#9888; HELPS NER OTP
                    </span>
                  </td>
                </tr>
              </table>
              <p style="color:rgba(255,255,255,0.8);font-size:13px;margin:10px 0 0;">
                Bangladesh Emergency Response Network
              </p>
            </td>
          </tr>

     
          <tr>
            <td style="padding:36px 32px;">

              <p style="color:#B0BEC5;font-size:14px;margin:0 0 6px;">Hello,</p>
              <h2 style="color:#ffffff;font-size:20px;font-weight:600;margin:0 0 20px;">
                <%= name %>
              </h2>

              <p style="color:#B0BEC5;font-size:14px;line-height:1.7;margin:0 0 28px;">
                Use the OTP code below to verify your EmergencyBD account.
                This code is valid for <strong style="color:#ffffff;">10 minutes</strong> only.
              </p>

              <table width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 28px;">
                <tr>
                  <td align="center">
                    <div style="background:#1A1A2E;border:2px solid #C0392B;border-radius:10px;padding:24px 32px;display:inline-block;">
                      <p style="color:#B0BEC5;font-size:12px;margin:0 0 8px;letter-spacing:1px;text-transform:uppercase;">
                        Your OTP Code
                      </p>
                      <p style="color:#E74C3C;font-size:38px;font-weight:700;letter-spacing:10px;margin:0;font-family:monospace;">
                        <%= otp %>
                      </p>
                    </div>
                  </td>
                </tr>
              </table>

         
              <table width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 24px;">
                <tr>
                  <td style="background:rgba(192,57,43,0.1);border-left:3px solid #C0392B;border-radius:0 6px 6px 0;padding:12px 16px;">
                    <p style="color:#E74C3C;font-size:13px;margin:0;">
                      &#9888;&nbsp; Never share this OTP with anyone.
                      EmergencyBD will never ask for your OTP.
                    </p>
                  </td>
                </tr>
              </table>

              <p style="color:#78909C;font-size:13px;line-height:1.6;margin:0;">
                If you did not request this, please ignore this email.
                Your account remains safe and secure.
              </p>

            </td>
          </tr>

  
          <tr>
            <td style="padding:0 32px;">
              <div style="height:1px;background:rgba(255,255,255,0.07);"></div>
            </td>
          </tr>

    
          <tr>
            <td style="padding:20px 32px;text-align:center;">
              <p style="color:#78909C;font-size:12px;margin:0 0 6px;">
                &copy; 2026 EmergencyBD — Bangladesh Emergency Response Network
              </p>
              <p style="color:#78909C;font-size:11px;margin:0;">
                This is an automated email. Please do not reply.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>